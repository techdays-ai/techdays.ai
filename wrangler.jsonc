{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "techdays-ai",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [
    { "pattern": "techdays.ai", "custom_domain": true },
    { "pattern": "www.techdays.ai", "custom_domain": true }
  ],
  "workers_dev": true,
  "observability": {
    "enabled": true
  }
}
